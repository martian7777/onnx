<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VisionAI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Command bar -->
        <Border Grid.Row="0" Padding="16,10" Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="Local Vision AI" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <AppBarSeparator />
                <ToggleButton x:Name="StartStopButton" Content="Start" MinWidth="90"
                              Click="OnStartStopClick" />
                <ComboBox x:Name="SourceCombo" SelectedIndex="0" MinWidth="160"
                          Header="Source">
                    <ComboBoxItem Content="Webcam" />
                    <ComboBoxItem Content="Video file…" />
                </ComboBox>
                <StackPanel Orientation="Vertical" Width="200">
                    <TextBlock Text="Confidence" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Slider x:Name="ConfidenceSlider" Minimum="5" Maximum="90" Value="25"
                            StepFrequency="5" ValueChanged="OnConfidenceChanged" />
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="Idle" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Video + overlays -->
            <Border Grid.Column="0" Margin="12" CornerRadius="8" Background="Black"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <canvas:CanvasControl x:Name="VideoCanvas" Draw="OnCanvasDraw" ClearColor="Black" />
            </Border>

            <!-- Telemetry panel -->
            <Border Grid.Column="1" Margin="0,12,12,12" Padding="18" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="18">
                    <TextBlock Text="PERFORMANCE" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <StackPanel>
                        <TextBlock x:Name="FpsValue" Text="0.0" FontSize="46" FontWeight="Bold" />
                        <TextBlock Text="Frames / second" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock x:Name="LatencyValue" Text="0.0 ms" FontSize="30" FontWeight="Bold" />
                        <TextBlock Text="Inference latency (avg)" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="LatencyRange" Text="min – / max –" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="HARDWARE TARGET" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="HardwareValue" Text="(initializing)" FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="OBJECTS" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="DetectionCount" Text="0 detected" FontSize="14" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
