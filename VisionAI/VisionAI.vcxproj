<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <CppWinRTOptimized>true</CppWinRTOptimized>
    <CppWinRTRootNamespaceAutoMerge>true</CppWinRTRootNamespaceAutoMerge>
    <!-- Pure-code app: we author no WinRT runtime classes, so no self-metadata. -->
    <CppWinRTGenerateWindowsMetadata>false</CppWinRTGenerateWindowsMetadata>
    <MinimalCoreWin>true</MinimalCoreWin>
    <ProjectGuid>{7C2E9B34-5A18-4D6E-9F21-3B4C7D8E2200}</ProjectGuid>
    <ProjectName>VisionAI</ProjectName>
    <RootNamespace>VisionAI</RootNamespace>
    <DefaultLanguage>en-US</DefaultLanguage>
    <WindowsTargetPlatformVersion>10.0.22621.0</WindowsTargetPlatformVersion>
    <WindowsTargetPlatformMinVersion>10.0.17763.0</WindowsTargetPlatformMinVersion>
    <AppContainerApplication>false</AppContainerApplication>
    <UseWinUI>true</UseWinUI>
    <!-- Unpackaged + self-contained: WinAppSDK DLLs copied locally, WinRT
         activation via an embedded reg-free SxS manifest. Keeps the installed
         framework out of the DLL search path so our app-local ORT 1.24 loads. -->
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <EnableMsixTooling>false</EnableMsixTooling>
    <AppxPackage>false</AppxPackage>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
    <WholeProgramOptimization Condition="'$(Configuration)'=='Release'">true</WholeProgramOptimization>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup>
    <OutDir>$(SolutionDir)build\$(Platform)\$(Configuration)\$(ProjectName)\</OutDir>
    <IntDir>$(SolutionDir)build\obj\$(Platform)\$(Configuration)\$(ProjectName)\</IntDir>
    <ResolveNuGetPackages>false</ResolveNuGetPackages>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeader>Use</PrecompiledHeader>
      <PrecompiledHeaderFile>pch.h</PrecompiledHeaderFile>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <WarningLevel>Level3</WarningLevel>
      <AdditionalIncludeDirectories>$(MSBuildProjectDirectory);$(MSBuildProjectDirectory)\thirdparty;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <Optimization Condition="'$(Configuration)'=='Release'">MaxSpeed</Optimization>
      <Optimization Condition="'$(Configuration)'=='Debug'">Disabled</Optimization>
      <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <!-- Delay-load ORT so the app-local 1.24 DLL (loaded explicitly first in
           wWinMain) wins over the WindowsAppRuntime framework's bundled 1.23. -->
      <DelayLoadDLLs>onnxruntime.dll;%(DelayLoadDLLs)</DelayLoadDLLs>
      <AdditionalDependencies>delayimp.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClInclude Include="pch.h" />
    <ClCompile Include="pch.cpp">
      <PrecompiledHeader>Create</PrecompiledHeader>
    </ClCompile>
  </ItemGroup>

  <!-- Pure-code WinUI shell -->
  <ItemGroup>
    <ClInclude Include="App.h" />
    <ClInclude Include="MainWindow.h" />
    <ClCompile Include="main.cpp" />
    <ClCompile Include="App.cpp" />
    <ClCompile Include="MainWindow.cpp" />
  </ItemGroup>

  <!-- Reusable modules -->
  <ItemGroup>
    <ClInclude Include="Inference\Detection.h" />
    <ClInclude Include="Inference\YoloDetector.h" />
    <ClInclude Include="Inference\Nms.h" />
    <ClInclude Include="Capture\FrameSource.h" />
    <ClInclude Include="Telemetry\Stats.h" />
    <ClCompile Include="Inference\YoloDetector.cpp">
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
    </ClCompile>
    <ClCompile Include="Inference\Nms.cpp">
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
    </ClCompile>
    <ClCompile Include="Telemetry\Stats.cpp">
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
    </ClCompile>
    <ClCompile Include="Capture\FrameSource.cpp" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CppWinRT" Version="2.0.250303.1" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260710003" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime.DirectML" Version="1.24.4" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

  <!-- Copy model + labels next to the exe so AssetPath() (exe\Assets) resolves. -->
  <Target Name="CopyVisionAssets" AfterTargets="Build">
    <ItemGroup>
      <_VaiAssets Include="$(MSBuildProjectDirectory)\Assets\yolov8n.onnx;$(MSBuildProjectDirectory)\Assets\coco.names" />
    </ItemGroup>
    <Copy SourceFiles="@(_VaiAssets)" DestinationFolder="$(OutDir)Assets" SkipUnchangedFiles="true" />
  </Target>

  <!-- The WindowsAppSDK ML component copies its own (older) onnxruntime/DirectML
       into the output, shadowing the ORT DirectML nuget we compiled against.
       Force our matching 1.24 build back over the output, last. -->
  <Target Name="ForceOnnxRuntimeVersion" AfterTargets="Build;CopyVisionAssets">
    <ItemGroup>
      <_VaiOrt Include="$(NuGetPackageRoot)microsoft.ml.onnxruntime.directml\1.24.4\runtimes\win-x64\native\onnxruntime.dll" />
      <_VaiOrt Include="$(NuGetPackageRoot)microsoft.ml.onnxruntime.directml\1.24.4\runtimes\win-x64\native\onnxruntime_providers_shared.dll" />
      <_VaiOrt Include="$(NuGetPackageRoot)microsoft.ai.directml\1.15.4\bin\x64-win\DirectML.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_VaiOrt)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="false" OverwriteReadOnlyFiles="true" />
  </Target>

  <!-- Generate the reg-free WinRT activation manifest (self-contained) and embed
       it into the exe so unpackaged launch activates WinUI classes. -->
  <Target Name="EmbedWinRTManifest" AfterTargets="Build" DependsOnTargets="CreateWinRTRegistration">
    <Copy SourceFiles="$(IntDir)Manifests\app.manifest" DestinationFiles="$(OutDir)$(TargetName).exe.manifest" SkipUnchangedFiles="true" />
    <Exec Command="&quot;$(ManifestTool)&quot; -nologo -manifest &quot;$(OutDir)$(TargetName).exe.manifest&quot; -outputresource:&quot;$(OutDir)$(TargetName).exe;#1&quot;" />
  </Target>
</Project>
